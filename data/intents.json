[
  {
    "name": "set_volume",
    "patterns": ["音量.*"],
    "slots": {"value": "音量.*?(\\d+)"}
  },
  {
    "name": "open_system_panel",
    "patterns": [
      "打开设置", "设置",
      "打开控制面板", "控制面板",
      "任务管理器", "打开任务管理器",
      "网络设置", "无线设置",
      "蓝牙设置",
      "声音设置", "音频设置",
      "显示设置", "屏幕设置",
      "电源设置",
      "个性化设置", "主题设置",
      "应用设置", "应用管理",
      "任务栏设置",
      "投影设置", "投屏",
      "截图", "截屏",
      "清空回收站",
      "打开浏览器", "浏览器"
    ],
    "slots": {
      "panel": "(?:打开|)(设置|控制面板|任务管理器|网络设置|无线设置|蓝牙设置|声音设置|音频设置|显示设置|屏幕设置|电源设置|个性化设置|主题设置|应用设置|应用管理|任务栏设置|投影设置|投屏|截图|截屏|清空回收站|浏览器)"
    }
  },
  {
    "name": "open_app",
    "patterns": ["打开.*", "启动.*"],
    "slots": {"app_name": "(?:打开|启动)\\s*(.*)"}
  },
  {
    "name": "close_app",
    "patterns": ["关闭.*", "退出.*"],
    "slots": {"app_name": "(?:关闭|退出)\\s*(.*)"}
  },
  {
    "name": "set_timer",
    "patterns": ["定时.*", "闹钟.*"],
    "slots": {"minutes": "(\\d+)\\s*分钟"}
  },
  {
    "name": "douyin_control",
    "patterns": ["抖音.*", "抖音(.+)", "douyin.*"],
    "slots": {
      "action": "(?:抖音|douyin)?\\s*(点赞|收藏|关注|评论|分享|暂停|播放|全屏|网页全屏|小窗|自动连播|清屏|弹幕|不感兴趣|相关推荐|作者主页|复制口令|上滑|下滑|快进|快退|音量加|音量减|稍后再看)"
    }
  },
  {
    "name": "systemShutdown",
    "patterns": ["关机", "关闭系统", "关电脑"],
    "slots": {}
  },
  {
    "name": "systemReboot",
    "patterns": ["重启", "重新启动", "重启电脑", "重新启动电脑"],
    "slots": {}
  },
  {
    "name": "systemLock",
    "patterns": ["息屏", "锁屏", "锁定电脑", "锁电脑"],
    "slots": {}
  },
  {
    "name": "systemSleep",
    "patterns": ["休眠", "睡眠", "待机"],
    "slots": {}
  }
]